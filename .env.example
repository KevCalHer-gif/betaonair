DATABASE_URL=postgresql://admin:localpass@localhost:5432/betaonair_db
PAYLOAD_SECRET=YOUR_SECRET_HERE
# URL pública del sitio (ej: https://betaonair.com)
NEXT_PUBLIC_SITE_URL=your-site-url
# URL base de la API de Payload (ej: http://localhost:3000)
NEXT_PUBLIC_API_URL=your-api-url
GROX_API_KEY=your-grox-api-key-here
# SMTP — Resend (https://resend.com) — necesario para forgot/reset password
RESEND_API_KEY=re_xxxxxxxxxxxx
# Google Analytics — Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
